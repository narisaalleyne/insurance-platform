NODE_ENV=development
PORT=5001

MONGODB_URI=mongodb://127.0.0.1:27017/insurance_platform
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=2h

FRONTEND_URL=http://localhost:3000

HTTPS_PFX_PATH=./cert/server.pfx
HTTPS_PFX_PASSPHRASE=replace_with_pfx_password

KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=northstar
KEYCLOAK_ISSUER=http://localhost:8080/realms/northstar
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/northstar/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=frontend-web
KEYCLOAK_BACKEND_CLIENT_ID=backend-api
KEYCLOAK_BACKEND_CLIENT_SECRET=backend-secret