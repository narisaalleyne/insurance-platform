# ===============================
# KEYCLOAK ADMIN
# ===============================
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin123

# ===============================
# DATABASE (PostgreSQL)
# ===============================
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak123

KC_DB=postgres
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak123
KC_DB_URL_HOST=keycloak-db
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak

# ===============================
# KEYCLOAK SERVER
# ===============================
KC_HOSTNAME=localhost
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080

# Dev mode (no TLS)
KC_PROXY=edge

# ===============================
# REALM / CLIENT DEFAULTS (for your app)
# ===============================
KEYCLOAK_REALM=northstar

# Frontend client
KEYCLOAK_CLIENT_ID=frontend-web
KEYCLOAK_CLIENT_SECRET=frontend-secret

# Backend client (optional)
KEYCLOAK_BACKEND_CLIENT_ID=backend-api
KEYCLOAK_BACKEND_CLIENT_SECRET=backend-secret

# ===============================
# URLs (used by your app later)
# ===============================
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/northstar

# OpenID endpoints
KEYCLOAK_AUTH_URL=http://localhost:8080/realms/northstar/protocol/openid-connect/auth
KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/northstar/protocol/openid-connect/token
KEYCLOAK_USERINFO_URL=http://localhost:8080/realms/northstar/protocol/openid-connect/userinfo
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/northstar/protocol/openid-connect/certs

# ===============================
# FRONTEND REDIRECTS
# ===============================
KEYCLOAK_REDIRECT_URI=http://localhost:3000/auth/keycloak/callback
KEYCLOAK_LOGOUT_REDIRECT_URI=http://localhost:3000

# ===============================
# FRONTEND APP URL
# ===============================
FRONTEND_URL=http://localhost:3000

# ===============================
# BACKEND API URL
# ===============================
BACKEND_URL=http://localhost:5000